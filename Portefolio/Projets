/* ===== GLITTER TITLES ===== */

.glitter-text{
background:linear-gradient(
90deg,
#b8860b,
#ffd700,
#fff1a8,
#ffd700,
#b8860b
);
background-size:300%;
-webkit-background-clip:text;
-webkit-text-fill-color:transparent;
animation:glitter 3s infinite linear;
}

@keyframes glitter{
0%{background-position:0%;}
100%{background-position:300%;}
}

