      color: #b5a400;
    }

    h3 {
      color: #E8C71C;
    }

    /* ===== GLITTER TITRES ===== */
    .glitter-text {
      background: linear-gradient(
        90deg,
        #b8860b,
        #ffd700,
        #fff1a8,
        #ffd700,
        #b8860b
      );
      background-size: 300%;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: glitter 3s infinite linear;
    }

    @keyframes glitter {
      0% { background-position: 0%; }
      100% { background-position: 300%; }
    }

    /* ===== HEADER ===== */
    header {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: #000;
      color: #fff;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 10%;
      flex-wrap: wrap;
    }

    header .logo img {
      width: 80px;
      height: 80px;
      border-radius: 50%;
    }

    nav ul {
      list-style: none;
      display: flex;
      gap: 25px;
      margin: 0;
      padding: 0;
    }

    nav a {
      color: #fff;
      font-weight: 600;
    }

    nav a:hover {
      color: #DECE31;
    }

    /* ===== MAIN ===== */
    main {
      padding: 60px 10%;
    }

    main section {
      margin-bottom: 60px;
    }

    main h2 {
      font-size: 1.8rem;
      color: #000;
      border-left: 5px solid #DECE31;
      padding-left: 10px;
      margin-bottom: 20px;
    }

    /* ===== CARTES ===== */
    .stage, .Projet {
      background: #f9f9f9;
      border-radius: 12px;
      padding: 20px;
      margin-bottom: 25px;
      border: 1px solid #ffd70055;
      transition: transform 0.3s ease, box-shadow 0.3s ease, border 0.3s ease;
    }

    .stage:hover, .Projet:hover {
      transform: translateY(-5px);
      box-shadow: 0 5px 15px rgba(255,215,0,0.3);
      border: 1px solid #ffd700;
    }

    h4 {
      font-size: 1.2rem;
      color: #000;
      margin-bottom: 5px;
    }

    p {
      margin-bottom: 10px;
    }

    /* ===== FOOTER ===== */
    footer {
      background: #111827;
      color: white;
      padding: 30px 20px;
      text-align: center;
    }

    footer p {
      margin: 5px 0;
      font-size: 0.9rem;
      color: #9ca3af;
    }

    /* ===== NOTE CAPTURES D'ÉCRAN ===== */
    .note-captures {
